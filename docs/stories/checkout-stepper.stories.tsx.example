import type { Meta, StoryObj } from "@storybook/react";
import { CheckoutStepper } from "./checkout-stepper";

const meta: Meta<typeof CheckoutStepper> = {
  title: "UI/CheckoutStepper",
  component: CheckoutStepper,
  parameters: {
    layout: "centered",
  },
  tags: ["autodocs"],
  argTypes: {
    currentStep: {
      control: { type: "number", min: 1, max: 3 },
      description: "The current active step (1-based index)",
    },
    onStepClick: { action: "stepClicked" },
  },
};

export default meta;
type Story = StoryObj<typeof CheckoutStepper>;

const STEPS = [
  { id: 1, label: "Summary" },
  { id: 2, label: "Order Type" },
  { id: 3, label: "Payment" },
];

export const Default: Story = {
  args: {
    currentStep: 1,
    steps: STEPS,
  },
};

export const Step2: Story = {
  args: {
    currentStep: 2,
    steps: STEPS,
  },
};

export const Step3: Story = {
  args: {
    currentStep: 3,
    steps: STEPS,
  },
};

export const Interactive: Story = {
  args: {
    currentStep: 2,
    steps: STEPS,
    onStepClick: (id) => console.log(`Step ${id} clicked`),
  },
};

export const MobileView: Story = {
  parameters: {
    viewport: {
      defaultViewport: "mobile1",
    },
  },
  args: {
    currentStep: 2,
    steps: STEPS,
    className: "max-w-[320px]",
  },
};
