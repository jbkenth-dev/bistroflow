{
  "framework": "nextjs",
  "functions": {
    "php-backend/public/api/*.php": {
      "runtime": "vercel-php@0.7.0"
    },
    "php-backend/public/api/**/*.php": {
      "runtime": "vercel-php@0.7.0"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/php-backend/public/api/$1" }
  ]
}
